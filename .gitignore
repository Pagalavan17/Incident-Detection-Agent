# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — Incident Response Agent
#
# Sections:
#   1. Environment & Secrets
#   2. Node.js
#   3. TypeScript Build Output
#   4. IDE & OS
#   5. Docker & Container Artefacts
#   6. Data & Reports (local, not committed)
#   7. Test Artefacts
#   8. Logs
# ─────────────────────────────────────────────────────────────────────────────

# ─── 1. Environment & Secrets ─────────────────────────────────────────────────
# NEVER commit actual keys — only the .env.example template
.env
.env.*
!.env.example

# ─── 2. Node.js ───────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.yarn/

# ─── 3. TypeScript Build Output ───────────────────────────────────────────────
dist/
*.tsbuildinfo
*.js.map
*.d.ts.map

# ─── 4. IDE & OS ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ─── 5. Docker & Container Artefacts ──────────────────────────────────────────
# Docker volumes are stored locally; do not commit them
docker/volumes/
*.pid

# ─── 6. Data & Reports (local only) ───────────────────────────────────────────
# Generated logs, embeddings, and post-mortems stay local
data/raw/
data/processed/
reports/generated/

# Keep placeholder .gitkeep files so empty folders are tracked
!data/.gitkeep
!reports/.gitkeep

# ─── 7. Test Artefacts ────────────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
*.snap

# ─── 8. Application Logs ──────────────────────────────────────────────────────
logs/
*.log
