{
  "name": "incident-response-agent",
  "version": "0.1.0",
  "description": "AI-powered Incident Response & Post-Mortem Copilot — HiDevs × Mastra Hackathon",
  "author": "HiDevs Team",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "tsx dist/index.js",
    "typecheck": "tsc --noEmit",
    "generate-logs": "tsx src/scripts/generateLogs.ts",
    "setup-qdrant": "tsx src/scripts/setupQdrant.ts",
    "seed-qdrant": "tsx src/scripts/seedQdrant.ts",
    "lint": "eslint src --ext .ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.110.0",
    "@mastra/core": "^1.50.1",
    "@mastra/openai": "^1.1.0",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-node": "0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/sdk-node": "0.220.0",
    "@qdrant/js-client-rest": "1.18.0",
    "axios": "1.18.1",
    "dotenv": "17.4.2",
    "express": "4.22.2",
    "openai": "6.45.0",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "remeda": "2.39.0",
    "tsx": "4.23.0",
    "uuid": "14.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "eslint": "9.29.0",
    "mastra": "^1.18.2",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  }
}
