# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Incident Response Agent
#
# PURPOSE:
#   Template for local environment variables.
#   Copy this file to .env and fill in your actual values.
#   NEVER commit the .env file — only this .env.example template.
#
# USAGE:
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────

# Runtime environment: development | staging | production
NODE_ENV=development

# HTTP port the Express API server listens on
PORT=3000

# ─── AI Model Providers ────────────────────────────────────────────────────────

# Anthropic Claude — used for RCA and post-mortem generation
# Obtain at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — used for embeddings and auxiliary generation tasks
# Obtain at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── Safety Layer ─────────────────────────────────────────────────────────────

# Enkrypt AI Guardrails — validates LLM outputs before remediation actions
# Obtain at: https://enkryptai.com/
ENKRYPTAI_GUARDRAILS_API_KEY=your_enkryptai_api_key_here

# ─── Vector Database ──────────────────────────────────────────────────────────

# Qdrant REST endpoint — defaults to local Docker instance
# For Qdrant Cloud: https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# Optional: Qdrant API key (required for Qdrant Cloud deployments)
QDRANT_API_KEY=

# ─── OpenTelemetry (Optional) ─────────────────────────────────────────────────

# OTLP endpoint for distributed tracing (e.g., Jaeger, Grafana Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=incident-response-agent
