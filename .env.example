# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Incident Response Agent
#
# PURPOSE:
#   Template for local environment variables.
#   Copy this file to .env and fill in your actual values.
#   NEVER commit the .env file — only this .env.example template.
#
# USAGE:
#   cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ──────────────────────────────────────────────────────────────

# Runtime environment: development | staging | production
NODE_ENV=development

# HTTP port the Express API server listens on
PORT=3000

# ─── LLM Provider Selection ───────────────────────────────────────────────────
# Which provider the RCA/Remediation/Guardrails/Post-Mortem agents use.
# Change this + the matching key below to fail over to another provider.
LLM_PROVIDER=anthropic   # one of: openai | anthropic | groq | google | deepseek

ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_API_KEY=your_anthropic_api_key_here

GROQ_MODEL=openai/gpt-oss-120b
GROQ_API_KEY=your_groq_api_key_here

GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_API_KEY=your_google_api_key_here

DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# OpenAI — still required for embeddings (Qdrant similarity search) regardless
# of which LLM_PROVIDER is active above.
OPENAI_API_KEY=your_openai_api_key_here

# ─── Safety Layer ─────────────────────────────────────────────────────────────

# Enkrypt AI Guardrails — validates LLM outputs before remediation actions
# Obtain at: https://enkryptai.com/
ENKRYPTAI_GUARDRAILS_API_KEY=your_enkryptai_api_key_here

# ─── Vector Database ──────────────────────────────────────────────────────────

# Qdrant REST endpoint — defaults to local Docker instance
# For Qdrant Cloud: https://<cluster-id>.<region>.aws.cloud.qdrant.io
QDRANT_URL=http://localhost:6333

# Optional: Qdrant API key (required for Qdrant Cloud deployments)
QDRANT_API_KEY=

# ─── OpenTelemetry (Optional) ─────────────────────────────────────────────────

# OTLP endpoint for distributed tracing (e.g., Jaeger, Grafana Tempo)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=incident-response-agent
